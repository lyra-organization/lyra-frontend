{
  "expo": {
    "name": "Lyra",
    "slug": "lyra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lyra",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios"
    ],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.omarsaleh.lyra"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Lyra needs your location to find compatible people nearby.",
          "locationAlwaysPermission": "Lyra needs background location to notify you when someone compatible is near.",
          "locationWhenInUsePermission": "Lyra needs your location to guide you toward your match.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
